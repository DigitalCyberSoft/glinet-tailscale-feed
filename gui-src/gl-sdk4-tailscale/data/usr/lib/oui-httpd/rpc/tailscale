--[[
    @object-name: tailscale
    @object-desc: tailscale settings
--]]

local uci = require "uci"
local cjson = require "cjson"
local lnet = require "oui.network"
local fs = require "oui.fs"
local rpc = require "oui.rpc"
local validator = require "gl.validator"

local M = {}

-- no_peers=true adds `--peers=false`: the daemon then omits the peer list from
-- the JSON. On a tailnet with many peers that shrinks the payload ~17x (52KB ->
-- 3KB on a real GL-E750) and the matching cjson.decode cost with it. Callers that
-- only read top-level fields (BackendState, Self, User, TailscaleIPs, AuthURL)
-- MUST pass no_peers; get_exit_node_info needs the peer list and MUST NOT.
local function tailscale_status(wait_time, no_peers)
    local cmd = {"timeout", wait_time or "2", "/usr/sbin/tailscale", "status", "--json"}
    if no_peers then
        cmd[#cmd + 1] = "--peers=false"
    end
    local r1 = ngx.pipe.spawn(cmd)
    if r1 then
        local data = r1:stdout_read_all()
        if data and string.len(data) ~= 0 then
            local r = cjson.decode(data)
            if r and type(r) == "table" then
                return r
            end
        end
        end

    return nil
end

-- Recommended UI status-poll cadence (ms), reported to the panel via get_config.
-- The panel polls get_status on this interval and every poll forks the tailscale
-- binary to query the daemon: cheap output (--peers=false) but a real per-poll CPU
-- hit on a single-core mips. Low-flash GL routers (< 256 MB total flash, e.g. the
-- 128 MB-NAND E750) are the weak tier and poll slower. Flash is summed from
-- /proc/mtd; eMMC/large-NAND devices that expose no /proc/mtd fall through to the
-- fast default -- those are the high tier, so not throttling them is correct.
local FLASH_SLOW_THRESHOLD = 256 * 1024 * 1024  -- bytes
local POLL_FAST = 5000   -- stock cadence
local POLL_SLOW = 20000  -- low-flash cadence
local function poll_interval_ms()
    local f = io.open("/proc/mtd", "r")
    if not f then return POLL_FAST end
    local total = 0
    for line in f:lines() do
        local hexsize = line:match("^mtd%d+:%s+(%x+)")
        if hexsize then total = total + tonumber(hexsize, 16) end
    end
    f:close()
    if total > 0 and total < FLASH_SLOW_THRESHOLD then
        return POLL_SLOW
    end
    return POLL_FAST
end

local function get_exit_node_info()
    local r = tailscale_status()
    local res = {}
    local exit_node_list = {}

    if not r or not r.Peer or type(r.Peer) ~= "table" then
        return res
    end

    local peer_list = r.Peer
    for k, v in pairs(peer_list) do
        if k and v and v.ExitNodeOption then
            if v.TailscaleIPs and type(v.TailscaleIPs) == "table" and v.TailscaleIPs[1] then
                exit_node_list[#exit_node_list + 1] = v.TailscaleIPs[1]
            end
        end
    end

    if r.ExitNodeStatus
        and r.ExitNodeStatus.TailscaleIPs
        and type(r.ExitNodeStatus.TailscaleIPs) == "table" then
        local addr = r.ExitNodeStatus.TailscaleIPs[1]
        local pos  = string.find(addr, "/")
        res.exit_node_ip = string.sub(addr,1, pos-1)
    end

    res.exit_node_list = exit_node_list

    return res
end

--[[
    @method-type: call
    @method-name: get_status
    @method-desc: Get tailscale status

    @out string   status        Status of tailscale [1:login required; 2:authorization required; 3:running; 4:connecting]
    @out string   login_name    Login username
    @out string   address_v4    Ipv4 address
    @out array    dns           Dns servers
    @out number   ?err_code     Error code [-1:Failed to get status]
    @out string   ?err_msg      Error message
    @in-example:  {"jsonrpc":"2.0","method":"call","params":["","tailscale","get_status",{}],"id":1}
    @out-example: {"id":1,"jsonrpc":"2.0","result":{"login_name":"gl-fan****","status":3,"dns":["192.168.101.10","114.114.114.114"],"address_v4":"100.66.166.89"}}
--]]

function M.get_status()
    local r = tailscale_status(nil, true)  -- peers not needed; skip them (~17x smaller)
    local res = {}
    local dns = {}
    local c = uci.cursor()

    if r and r.BackendState then
        if r.BackendState == "NeedsLogin" then
            res.status = 1
        end

        if r.BackendState == "NeedsMachineAuth" then
            res.status = 2
        end

        if r.BackendState == "Running" then
            res.status = 3
        end

        if r.BackendState == "Starting" or r.BackendState == "NoState" or r.BackendState == "Starting" or r.BackendState == "InUseOtherUser" then
            res.status = 4
        end

        if r.User and type(r.User) == "table" then
            local user_list = r.User
            if r.Self and type(r.Self) == "table" and r.Self.UserID then
                for k, v in pairs(user_list) do
                    if k and v and v.LoginName then
                        if v.ID and r.Self.UserID == v.ID then
                            res.login_name = v.LoginName
                        end
                    end
                end
            end
        end

        if r.TailscaleIPs then
            if r.TailscaleIPs and type(r.TailscaleIPs) == "table" and r.TailscaleIPs[1] then
                res.address_v4 = r.TailscaleIPs[1]
            end
        end
    end

    local mode = c:get("gl-dns", "@dns[0]", "mode") or "auto"
    if mode == "manual" or mode == "proxy"then
        dns = c:get("dhcp", "@dnsmasq[0]", "server") or {}
    elseif mode == "auto" then
        local resolvfile = c:get("dhcp", "@dnsmasq[0]", "resolvfile") or ""
        if fs.access(resolvfile) then
            for l in io.lines(resolvfile) do
                local nameserver = l:match("nameserver (%S+)")
                if nameserver then
                    dns[#dns + 1] = nameserver
                end
            end
        end

        local function parse_vpn_resolv(name)
            local path = "/tmp/resolv.conf." .. name
            if fs.access(path) then
                for l in io.lines(path) do
                    local nameserver = l:match("nameserver (%S+)")
                    if nameserver then
                        dns[#dns + 1] = nameserver
                    end
                end
            end
        end
        parse_vpn_resolv("ovpn")
        parse_vpn_resolv("wg")
    end

    local tmp_dns ={}
    for _, item in ipairs(dns) do
        if not item:match(":") then
            tmp_dns[#tmp_dns + 1] = string.match(item, "([^#]+)")
        end
    end
    res.dns = tmp_dns

    return res
end

--[[
    @method-name: get_auth_url
    @method-type: call
    @method-desc: Get tailscale login link

    @out string   auth_url    Login link
    @in-example:  {"jsonrpc":"2.0","id":1,"method":"call","params":["","tailscale","get_auth_url"]}
    @out-example: {"jsonrpc": "2.0", "id": 1, "result": {"auth_url": "https://login.tailscale.com/a/xxxxxx"}}
--]]

function M.get_auth_url()
    local res = {}
    local r = tailscale_status("5", true)

    -- Fast path: the daemon is already holding a login URL -> return it immediately.
    -- A full "gl_tailscale restart" re-runs the control handshake and costs ~50s on
    -- an mips e750; once the user has enabled Tailscale the daemon sits at NeedsLogin
    -- already holding the current URL, so restarting just regenerates the same link
    -- the slow way. (Empty string is TRUTHY in Lua, so the "~= \"\"" guard is
    -- load-bearing: status reports AuthURL="" for a few seconds while registering.)
    if r and r.AuthURL and r.AuthURL ~= "" then
        res.auth_url = r.AuthURL
        return res
    end

    -- Already logged in -> no link to hand out.
    if r and r.BackendState == "Running" then
        return res
    end

    -- Restart ONLY if the daemon is not already coming up. If it is registering
    -- (NeedsLogin/Starting with an empty URL) a restart would throw away the
    -- in-progress login and slow things down, so just poll for the URL it is
    -- already fetching. Restart covers the "enabled in config but daemon dead" case.
    if r == nil or r.BackendState == "Stopped" or r.BackendState == "NoState" then
        ngx.pipe.spawn({"/usr/bin/gl_tailscale", "restart"}):wait()
    end

    local result
    for _tsi = 1, 25 do
        ngx.sleep(2)
        result = tailscale_status("5", true)
        if result and result.AuthURL and result.AuthURL ~= "" then break end
    end
    if result and result.AuthURL and result.AuthURL ~= "" then
        res.auth_url = result.AuthURL
    end
    return res
end

--[[
    @method-name: get_config
    @method-type: call
    @method-desc: Get tailscale settings

    @out bool    enabled        Whether to enable [false：Disable; true：Enable]
    @out bool    wan_enabled    Access the wan port network [false：Disable; true：Enable]
    @out bool    lan_enabled    Access the lan port network [false：Disable; true：Enable]
    @out string  lan_ip         Lan ip
    @out string  exit_node_ip   Device exit node IP

    @in-example:  {"jsonrpc":"2.0","id":1,"method":"call","params":["","tailscale","get_config"]}
    @out-example: {"id":1,"jsonrpc":"2.0","result":{"wan_enabled":true,"lan_ip":"192.168.8.0\/24","enabled":true,"lan_enabled":true}}
--]]

function M.get_config()
    local res = {}
    local c = uci.cursor()
    local lanip = c:get("network","lan", "ipaddr")
    local lanmask = c:get("network", "lan", "netmask")

    res.enabled = c:get("tailscale", "settings", "enabled") == "1"
    res.lan_enabled = c:get("tailscale", "settings", "lan_enabled") == "1"
    res.wan_enabled = c:get("tailscale", "settings", "wan_enabled") == "1"
    res.lan_gateway = c:get("tailscale", "settings", "lan_gateway") == "1"
    res.advertise_exit_node = c:get("tailscale", "settings", "advertise_exit_node") == "1"
    res.exit_node_ip = c:get("tailscale", "settings", "exit_node_ip")
    -- Panel toggle: preserve the Tailscale stack across a GL firmware upgrade
    -- (writes /etc/sysupgrade.conf). Off by default.
    res.keep_on_upgrade = c:get("tailscale", "settings", "keep_on_upgrade") == "1"
    -- Leak-protection killswitch (blackhole LAN if a selected exit node drops).
    -- Default on: only off when explicitly set to "0".
    res.killswitch = c:get("tailscale", "settings", "killswitch") ~= "0"
    -- tailscaled binary source: 'feed' (opkg package) or 'admonstrator'
    -- (ts-admon-update), plus whether any binary is actually installed (the glue no
    -- longer forces one, so the panel can warn when neither source is present).
    res.binary_source = c:get("tailscale", "settings", "binary_source") or "feed"
    res.binary_present = fs.access("/usr/sbin/tailscaled")
    -- Self-hosted control server (e.g. Headscale); empty = official Tailscale.
    res.login_server = c:get("tailscale", "settings", "login_server") or ""

    if lanip and lanmask then
        local lan_info = lnet.ipcalc({lanip, lanmask})
        res.lan_ip = lan_info.network.."/"..lan_info.prefix
    end

    -- Poll cadence for the panel's get_status loop; slower on low-flash hardware.
    res.poll_interval = poll_interval_ms()

    return res
end

--[[
    @method-name: get_exit_node_list
    @method-type: call
    @method-desc: Get tailscale settings

    @out array    exit_node_list     List of exit nodes

    @in-example:  {"jsonrpc":"2.0","id":1,"method":"call","params":["","tailscale","get_exit_node_list"]}
    @out-example: {"jsonrpc": "2.0", "id": 1, "result": {"exit_node_list":["100.91.50.xxx","100.71.64.xxx"]}}
--]]

function M.get_exit_node_list(params)
    local res = {}
    local c = uci.cursor()
    local enabled = c:get("tailscale", "settings", "enabled") == "1"

    if enabled then
        local exit_node_info = get_exit_node_info()

        if exit_node_info.exit_node_list then
            res.exit_node_list = exit_node_info.exit_node_list
        end

        if exit_node_info.exit_node_ip then
            res.exit_node_ip = exit_node_info.exit_node_ip
        end
    end

    return res
end

--[[
    @method-name: set_config
    @method-type: call
    @method-desc: Set tailscale settings

    @in  bool     enabled          Status of tailscale：true：Enable，false: Disable
    @in  bool     wan_enabled      Access the wan port network，true：Enable，false: Disable
    @in  bool     lan_enabled      Access the lan port network，true：Enable，false: Disable
    @in  bool     ?exit_node_ip    Exit node IP
    @out number   ?err_code        Error code,-1:Setup failed.
    @out string   ?err_msg         Error message

    @in-example:  {"jsonrpc":"2.0","id":1,"method":"call","params":["","tailscale","set_config",{"enabled":true,"lan_enabled":true,"wan_enabled":true,"exit_node_ip":"100.91.50.xxx"}]}

    @out-example: {"id":1,"jsonrpc":"2.0","result":[]}
--]]

function M.set_config(params)
    local c = uci.cursor()
    local enabled = params.enabled
    local wan_enabled = params.wan_enabled
    local lan_enabled = params.lan_enabled
    local lan_gateway = params.lan_gateway
    local advertise_exit_node = params.advertise_exit_node
    local keep_on_upgrade = params.keep_on_upgrade
    local killswitch = params.killswitch
    local exit_node_ip = params.exit_node_ip
    local login_server = params.login_server

    -- Borrowed from GL 2026: refuse when OpenVPN TAP site-to-site is active, which is
    -- incompatible with the tailscale0 routing this sets up.
    local ovpn_config = c:get("network", "ovpnclient", "config")
    local client_mode = ovpn_config and c:get("ovpnclient", ovpn_config, "mode") or ""
    if client_mode == "tap-s2s" and (c:get("network", "ovpnclient", "disabled") or "1") == "0" then
        return {
            err_code = 20022002,
            err_msg = "function does not work because TAP-S2S Mode is enabled"
        }
    end

    -- A node cannot advertise an exit node and use one at the same time
    -- (tailscale rejects it). Advertising wins: clear any selected exit node.
    if advertise_exit_node then
        exit_node_ip = ""
    end

    if not validator.base(enabled, "boolean", true) then
        return rpc.ERROR_CODE_INVALID_PARAMS, "invalid enabled"
    end

    if not validator.base(wan_enabled, "boolean", true) then
        return rpc.ERROR_CODE_INVALID_PARAMS, "invalid wan_enabled"
    end

    if not validator.base(lan_enabled, "boolean", true) then
        return rpc.ERROR_CODE_INVALID_PARAMS, "invalid lan_enabled"
    end

    if not validator.base(lan_gateway, "boolean", true) then
        return rpc.ERROR_CODE_INVALID_PARAMS, "invalid lan_gateway"
    end

    if not validator.base(advertise_exit_node, "boolean", true) then
        return rpc.ERROR_CODE_INVALID_PARAMS, "invalid advertise_exit_node"
    end

    if not validator.base(keep_on_upgrade, "boolean", true) then
        return rpc.ERROR_CODE_INVALID_PARAMS, "invalid keep_on_upgrade"
    end

    if not validator.base(killswitch, "boolean", true) then
        return rpc.ERROR_CODE_INVALID_PARAMS, "invalid killswitch"
    end

    if exit_node_ip ~= "" and exit_node_ip ~= nil and not validator.ip4addr(exit_node_ip) then
        return rpc.ERROR_CODE_INVALID_PARAMS, "invalid exit_node_ip"
    end

    -- Charset-restricted URL: gl_tailscale word-splits it into the `tailscale up`
    -- argv, so no whitespace (argument injection) and no shell metacharacters.
    if login_server ~= nil then
        if type(login_server) ~= "string" or #login_server > 256
            or (login_server ~= "" and not login_server:match("^https?://[%w%.%-:/_]+$")) then
            return rpc.ERROR_CODE_INVALID_PARAMS, "invalid login_server"
        end
    end

    local mode = c:get("glconfig", "general", "mode")
    if mode ~= "router" and enabled then
        return {
            err_code = 0,
            err_msg = "tailscale can only be used in router mode"
        }
    end

    if enabled then
        c:set("tailscale", "settings", "enabled", 1)
    end

    -- nil = the caller did not send the field: leave the stored value untouched.
    -- The old `if x then 1 else 0` wrote 0 for OMITTED fields too, so any partial
    -- caller wiped saved toggles -- most notably the panel's own disable path,
    -- which sends only {enabled=false}: every disable/enable cycle silently reset
    -- lan/wan/gateway/advertise and cleared the chosen exit node (seen live on the
    -- XE3000, "I have set them multiple times"). Explicit false still writes 0;
    -- keep_on_upgrade/killswitch below already followed this contract.
    local function set_bool(opt, v)
        if v == true then
            c:set("tailscale", "settings", opt, 1)
        elseif v == false then
            c:set("tailscale", "settings", opt, 0)
        end
    end
    set_bool("lan_enabled", lan_enabled)
    set_bool("wan_enabled", wan_enabled)
    set_bool("lan_gateway", lan_gateway)
    set_bool("advertise_exit_node", advertise_exit_node)

    -- gl_tailscale restart below re-applies the sysupgrade.conf block from
    -- keep_on_upgrade; killswitch default-on is handled in get_config and the
    -- ts_killswitch binary (killswitch != 0).
    set_bool("keep_on_upgrade", keep_on_upgrade)
    set_bool("killswitch", killswitch)

    -- nil (older panel that never sends it) leaves the control server unchanged;
    -- "" reverts to the official Tailscale service. On a CHANGE, log the node out
    -- first: tailscale refuses to switch --login-server while Running without
    -- --force-reauth (cli/up.go), and a control-plane switch is a new identity
    -- anyway -- the old network's login and exit nodes mean nothing on the new one.
    -- From the logged-out state the restart below applies the new server cleanly
    -- and the panel drops back to "login required".
    if login_server ~= nil then
        local prev = c:get("tailscale", "settings", "login_server") or ""
        if login_server ~= prev then
            c:set("tailscale", "settings", "login_server", login_server)
            local p = ngx.pipe.spawn({"/usr/sbin/tailscale", "logout"})
            if p then p:wait() end
            local state_file = c:get("tailscale", "settings", "state_file")
            if state_file then
                os.remove(state_file)
            end
            exit_node_ip = ""
        end
    end

    -- Same nil-preserving contract: "" clears the exit node (handleApply sends ""
    -- explicitly in non-manual mode, and the advertise/login_server branches above
    -- assign ""), an omitted field keeps the user's choice.
    if exit_node_ip ~= nil then
        c:set("tailscale", "settings", "exit_node_ip", exit_node_ip)
    end

    if enabled == false then
        c:set("tailscale", "settings", "enabled", 0)
    end

    c:commit("tailscale")
    -- Apply leak-protection killswitch from the freshly committed settings (borrowed
    -- from GL 2026: adds/removes the LAN blackhole rule based on exit-node usage).
    ngx.pipe.spawn({"/usr/bin/ts_killswitch"}):wait()
    fs.sync()
    ngx.pipe.spawn({"/usr/bin/gl_tailscale", "restart"})
end

--[[
    @method-type: call
    @method-name: logout
    @method-desc: Logout of tailscale

    @out number   ?err_code   Error code
    @out string   ?err_msg    Error message

    @in-example:  {"jsonrpc":"2.0","id":1,"method":"call","params":["","tailscale","logout"]}
    @out-example: {"id":1,"jsonrpc":"2.0","result":[]}
--]]
function M.logout()
    ngx.pipe.spawn({"/usr/sbin/tailscale", "logout"}):wait()
    local c = uci.cursor()
    c:set("tailscale", "settings", "exit_node_ip", "")
    c:commit("tailscale")
    -- clear the killswitch's LAN blackhole rule now that no exit node is selected
    ngx.pipe.spawn({"/usr/bin/ts_killswitch"}):wait()

    local state_file = c:get("tailscale", "settings", "state_file")
    if state_file then
        os.remove(state_file)
    end
    fs.sync()
    -- Re-seed the daemon's pending prefs from uci. logout + state removal wiped
    -- them, and nothing else runs a param-carrying `up` before the next browser
    -- login completes -- get_auth_url's fast path deliberately avoids the restart
    -- -- so a re-login would come up with DEFAULT prefs (no advertised routes, no
    -- exit node) while the panel still shows the configured toggles. Detached like
    -- set_config: a full restart takes ~50s on mips and the panel should not hang
    -- on Unbind. Also regenerates a fresh AuthURL for the fast path to hand out.
    ngx.pipe.spawn({"/usr/bin/gl_tailscale", "restart"})
end

--[[
    @method-type: call
    @method-name: login
    @method-desc: Log in with a pre-generated auth key (Tailscale or Headscale preauthkey)

    @in  string   auth_key    Auth key, e.g. tskey-auth-... or a Headscale preauthkey
    @out number   ?err_code   Error code [-1:login failed]
    @out string   ?err_msg    Error message

    @in-example:  {"jsonrpc":"2.0","id":1,"method":"call","params":["","tailscale","login",{"auth_key":"tskey-auth-xxxx"}]}
    @out-example: {"id":1,"jsonrpc":"2.0","result":[]}
--]]
function M.login(params)
    local key = params.auth_key
    -- Keys are opaque tokens (tskey-auth-... / Headscale hex); accept only token
    -- characters. The key is transient: it rides argv into gl_tailscale, is spent
    -- on one `up`, and is never stored (post-login auth lives in the state file).
    if type(key) ~= "string" or #key == 0 or #key > 512
        or not key:match("^[%w%-%._]+$") then
        return rpc.ERROR_CODE_INVALID_PARAMS, "invalid auth_key"
    end

    local c = uci.cursor()
    if c:get("tailscale", "settings", "enabled") ~= "1" then
        return { err_code = -1, err_msg = "tailscale is not enabled" }
    end

    -- Synchronous: gl_tailscale restart runs `up --auth-key=...` bounded at 60s
    -- and leaves the CLI's stderr in /tmp/ts_login_err for us. The panel calls
    -- this rpc with a long client timeout.
    os.remove("/tmp/ts_login_err")
    local p = ngx.pipe.spawn({"/usr/bin/gl_tailscale", "restart", key})
    if p then p:wait() end

    -- Anything past NeedsLogin means the key was accepted (Running, or still
    -- syncing the netmap, or waiting for machine authorization); the panel's
    -- status poll takes it from there.
    local r = tailscale_status("5", true)
    local state = r and r.BackendState or ""
    if state == "Running" or state == "Starting" or state == "NeedsMachineAuth" then
        return {}
    end

    -- Still not logged in: surface the CLI's own first stderr line, which carries
    -- the control server's reason (e.g. "backend error: invalid key: ...").
    local msg
    local ef = io.open("/tmp/ts_login_err", "r")
    if ef then
        msg = ef:read("*a")
        ef:close()
        msg = msg and msg:match("[^\r\n]+")
    end
    return { err_code = -1, err_msg = msg or "auth key login failed" }
end

--[[
    @method-type: call
    @method-name: set_binary
    @method-desc: Choose the tailscaled binary source and (re)install if needed

    @in  string   source   'feed' (opkg package) or 'admonstrator' (fetch tiny build)
    @out number   ?err_code
    @out string   ?err_msg
--]]
function M.set_binary(params)
    local source = params.source
    if source ~= "feed" and source ~= "admonstrator" then
        return rpc.ERROR_CODE_INVALID_PARAMS, "invalid source"
    end

    local c = uci.cursor()
    c:set("tailscale", "settings", "binary_source", source)
    c:commit("tailscale")
    fs.sync()

    if source == "admonstrator" then
        -- fetch Admonstrator's build; the script sets its own uci + persistence
        local r = ngx.pipe.spawn({"/usr/bin/ts-admon-update"})
        if r then r:wait() end
    end
    -- 'feed' only records the preference; the feed binary is installed via opkg.
    ngx.pipe.spawn({"/usr/bin/gl_tailscale", "restart"})
end

--[[
    @method-type: call
    @method-name: check_update
    @method-desc: Fetch our feed's index and report which of our packages have updates

    @out bool    update_available
    @out array   packages            list of {name, installed, available}
--]]
function M.check_update()
    -- Pull ONLY our feed's package index, not a full `opkg update`. `opkg update`
    -- refreshes every configured feed serially with no per-feed timeout, so one slow
    -- or dead unrelated feed (seen in the field: an employee-wifi feed hanging ~90s)
    -- blocks this rpc past the panel's 60s request timeout and surfaces as
    -- "Request timed out". Our feed is unsigned, so a plain wget is enough; the base
    -- URL (which carries the arch, e.g. .../glinet-tailscale-feed/mips_24kc) comes
    -- straight from opkg's own config so we track whatever arch this router installed.
    local base
    local cf = io.open("/etc/opkg/customfeeds.conf", "r")
    if cf then
        for line in cf:lines() do
            local u = line:match("(https?://%S+glinet%-tailscale%-feed%S*)")
            if u then base = u break end
        end
        cf:close()
    end
    if not base then
        return { update_available = false, packages = {} }
    end

    -- fetch + decompress the index in one short-bounded shell (timeout caps the wget)
    local feed_ver = {}
    local p = ngx.pipe.spawn({"sh", "-c",
        "timeout 20 wget -q -O /tmp/glits_Packages.gz '" .. base ..
        "/Packages.gz' && zcat /tmp/glits_Packages.gz"})
    local out = p and p:stdout_read_all() or ""
    if p then p:wait() end
    local pkg
    for line in out:gmatch("[^\n]+") do
        local n = line:match("^Package:%s*(%S+)")
        if n then pkg = n end
        local v = line:match("^Version:%s*(%S+)")
        if v and pkg then feed_ver[pkg] = v end
    end

    -- installed versions of our packages
    local inst_ver = {}
    local li = ngx.pipe.spawn({"opkg", "list-installed"})
    local liout = li and li:stdout_read_all() or ""
    if li then li:wait() end
    for line in liout:gmatch("[^\n]+") do
        local n, v = line:match("^(%S+)%s+%-%s+(%S+)")
        if n then inst_ver[n] = v end
    end

    local ours = {
        "tailscale", "tailscale-micro",
        "gl-sdk4-tailscale", "gl-sdk4-ui-tailscaleview", "gl-sdk4-tailscale-mullvad",
    }
    local packages = {}
    local installed = {}
    for _, name in ipairs(ours) do
        local iv = inst_ver[name]
        local fv = feed_ver[name]
        -- installed set: what the router is on now (drives the panel's "current
        -- version" display, including the up-to-date case where packages is empty).
        if iv then
            installed[#installed + 1] = { name = name, version = iv }
        end
        -- Only report a package that is installed AND has a strictly-newer feed
        -- version. Use opkg's own comparator: our versions carry a `1:` epoch, which
        -- a string compare would get wrong (git-2025.x vs 1:1.2.1-1).
        if iv and fv then
            local cmp = ngx.pipe.spawn({"opkg", "compare-versions", iv, "<<", fv})
            local newer = cmp and cmp:wait()  -- true only when installed << feed
            if newer then
                packages[#packages + 1] = { name = name, installed = iv, available = fv }
            end
        end
    end

    return {
        update_available = (#packages > 0),
        packages = packages,
        installed = installed,
    }
end

--[[
    @method-type: call
    @method-name: do_update
    @method-desc: Update all installed feed packages to the current build in one shot
--]]
function M.do_update()
    -- Detached: glits-upgrade reinstalls gl-sdk4-tailscale, whose postinst restarts
    -- rpcd -- which would kill THIS rpc worker mid-call. Fire-and-forget; the panel
    -- waits then refetches. Progress lands in /tmp/glits-upgrade.log.
    ngx.pipe.spawn({"sh", "-c", "(/usr/bin/glits-upgrade >/tmp/glits-upgrade.log 2>&1) &"}):wait()
end

return M
