#!/bin/sh

. /lib/functions/gl_util.sh

action="$1"
TS_POLICY_ROUTE=/tmp/ts_policy_route
TS_FIREWALL_SECTION=gltailscale
TAILSCALE_ROUTE_TABLE=52
TAILSCALE_DNS_SERVER="100.100.100.100"

# Older GL firmwares (e.g. GL-E750 4.3.26) don't ship the `ipcalc_network` helper
# newer builds provide, and no package on-device owns it. Stock /bin/ipcalc.sh emits
# the same NETWORK=/PREFIX= lines this script parses, so fall back to it when
# ipcalc_network is absent (else LAN/WAN subnet CIDRs come out empty and the panel's
# route toggles advertise nothing).
command -v ipcalc_network >/dev/null 2>&1 || ipcalc_network() { ipcalc.sh "$@"; }

if [ "$action" = "set_route" ];then
    sleep 5
    ip route add 100.64.0.0/10 dev tailscale0
fi

# Preserve the whole Tailscale stack across a GL firmware upgrade by listing it in
# /etc/sysupgrade.conf (itself a preserved conffile, so the list survives every future
# flash -- unlike a package keep.d that must be on disk at flash time). Gated on the
# panel toggle settings.keep_on_upgrade (unset = off; off by default). Managed block,
# rewritten each call.
apply_keep_on_upgrade() {
    local su=/etc/sysupgrade.conf keep
    keep=$(uci -q get tailscale.settings.keep_on_upgrade)
    [ -z "$keep" ] && keep=0
    touch "$su"
    sed -i '/tailscale-keep-BEGIN/,/tailscale-keep-END/d' "$su" 2>/dev/null
    [ "$keep" = "1" ] || return 0
    {
        echo '# tailscale-keep-BEGIN (managed by gl_tailscale; toggle in the Tailscale panel)'
        for p in \
            /usr/sbin/tailscaled /usr/sbin/tailscale \
            /etc/config/tailscale /etc/tailscale/ /etc/firewall.tailscale.sh \
            /etc/init.d/tailscale /etc/rc.d/S80tailscale \
            /etc/hotplug.d/iface/19-tailscale-iface /etc/hotplug.d/net/19-tailscale-net \
            /usr/bin/gl_tailscale /usr/bin/ts_killswitch /usr/bin/ts-admon-update /usr/bin/glits-upgrade /usr/lib/oui-httpd/rpc/tailscale \
            /www/views/gl-sdk4-ui-tailscaleview.common.js.gz \
            /www/i18n/gl-sdk4-ui-tailscaleview.de.json \
            /www/i18n/gl-sdk4-ui-tailscaleview.en.json \
            /www/i18n/gl-sdk4-ui-tailscaleview.es.json \
            /www/i18n/gl-sdk4-ui-tailscaleview.it.json \
            /www/i18n/gl-sdk4-ui-tailscaleview.ja.json \
            /www/i18n/gl-sdk4-ui-tailscaleview.zh-cn.json \
            /www/i18n/gl-sdk4-ui-tailscaleview.zh-tw.json \
            /usr/share/oui/menu.d/tailscaleview.json; do
            echo "$p"
        done
        echo '# tailscale-keep-END'
    } >> "$su"
}

if [ "$action" = "keep" ]; then
    apply_keep_on_upgrade
    exit 0
fi

apply_tailscale_mtu() {
    ts_mtu=$(uci -q get tailscale.settings.mtu)
    [ -n "$ts_mtu" ] && ip link set dev tailscale0 mtu "$ts_mtu" 2>/dev/null
}

add_policy_route()
{
    target=$1
    if [ -n "$target" ]; then
        route_param="to $target table main"
        /sbin/ip rule add $route_param
        echo $route_param >> $TS_POLICY_ROUTE
    fi
}

del_policy_route()
{
    /sbin/ip rule del to $TAILSCALE_DNS_SERVER lookup $TAILSCALE_ROUTE_TABLE pri 50
    if [ -f $TS_POLICY_ROUTE ]; then
        while read line; do
            if [ -n "$line" ]; then
                /sbin/ip rule del $line
            fi
        done < $TS_POLICY_ROUTE
        rm $TS_POLICY_ROUTE
    fi
}

add_network_policy_route()
{
    local interface=$1

    local disable=$(uci -q get network.$interface.disabled)
    exit_node_ip=$(uci -q get tailscale.settings.exit_node_ip)

    if [ -n "$exit_node_ip" ] && [ "$disable" = "0" ]; then
        local ipaddr=$(ubus call network.interface.$interface status | jsonfilter -e '@["ipv4-address"][0].address')
        local netmask=$(ubus call network.interface.$interface status | jsonfilter -e '@["ipv4-address"][0].mask')

        if [ -n "$ipaddr" ] && [ -n "$netmask" ]; then
            local network=$(ipcalc_network $ipaddr $netmask | awk -F= '/NETWORK/{print $2}')
            local prefix=$(ipcalc_network $ipaddr $netmask | awk -F= '/PREFIX/{print $2}')

            if [ -n "$network" ] && [ -n "$prefix" ]; then
                local cidr="$network/$prefix"
                local policy_route_param="from $cidr table main"

                /sbin/ip rule add $policy_route_param
                echo $policy_route_param >> $TS_POLICY_ROUTE
            fi
        fi
    fi
}


add_exit_node_rule()
{
    count=0
    while [ $count -le 5 ]
    do
        rule_exist=$(ip rule | grep "from all fwmark 0x80000/0x80000 lookup")
        ts_prio=$(ip rule | grep "from all lookup 52" |  awk -F':' '{print $1}' | head -n 1)
        if [ "$rule_exist" = "" ]; then
            if [ -n "$ts_prio" ]; then
                pre_prio=$(($ts_prio-1))
                policy_route_param="from all fwmark 0x80000/0x80000 lookup main prio $pre_prio"
                /sbin/ip rule add $policy_route_param
                echo $policy_route_param >> $TS_POLICY_ROUTE
            fi
        else
            break
        fi
        count=$(($count+1))
        sleep 1
    done
}

add_ts_fw_rule()
{
    if [ -f /etc/firewall.tailscale.sh ]; then
        /etc/firewall.tailscale.sh &
    fi
}

start_dns_poller() {
    local pid_file="/var/run/tailscale_dns_poller.pid"

    if [ -f "$pid_file" ] && kill -0 $(cat "$pid_file") 2>/dev/null; then
        return
    fi

    {
        local suffix=""
        local interval=2
        local max_interval=30
        local max_attempts=15

        for attempt in $(seq 1 $max_attempts); do
            suffix=$(timeout 2 tailscale status -json 2>/dev/null | jsonfilter -e '@.MagicDNSSuffix')

            if [ -n "$suffix" ] && [ "$suffix" != "null" ]; then
                current_domain=$(uci get dhcp.@dnsmasq[0].domain 2>/dev/null)
                if [ "$suffix" != "$current_domain" ]; then
                    uci set dhcp.@dnsmasq[0].domain="$suffix"
                    uci commit dhcp
                    /etc/init.d/dnsmasq restart
                fi
                break
            fi

            sleep $interval

            interval=$((interval * 2))
            [ $interval -gt $max_interval ] && interval=$max_interval
        done

        rm -f "$pid_file"
    } &

    echo $! > "$pid_file"
}

modify_dns_resolv()
{
    dns_suffix=$(timeout 2 tailscale status -json | jsonfilter -e '@.MagicDNSSuffix')
    rule_exist=$(grep "ts.net/100.100.100.100" /etc/dnsmasq.conf)
    current_domain=$(uci get dhcp.@dnsmasq[0].domain)

    if [ "$1" = "1" ]; then
        if [ -z "$(uci -q get tailscale.settings.original_domain)" ]; then
            uci set tailscale.settings.original_domain="$current_domain"
            uci commit tailscale
        fi

        if [ "$rule_exist" = "" ]; then
            echo "server=/ts.net/100.100.100.100" >> /etc/dnsmasq.conf
        fi

        if [ -n "$dns_suffix" ]; then
            uci set dhcp.@dnsmasq[0].domain="$dns_suffix"
            uci commit dhcp
        else
            start_dns_poller
        fi
        /etc/init.d/dnsmasq restart

    else
        local pid_file="/var/run/tailscale_dns_poller.pid"
        if [ -f "$pid_file" ]; then
            kill $(cat "$pid_file") 2>/dev/null
            rm -f "$pid_file"
        fi

        original_domain=$(uci -q get tailscale.settings.original_domain)
        if [ -n "$original_domain" ]; then
            uci set dhcp.@dnsmasq[0].domain="$original_domain"
            uci delete tailscale.settings.original_domain
            uci commit tailscale
        else
            uci set dhcp.@dnsmasq[0].domain="lan"
        fi
        uci commit dhcp

        if [ -n "$rule_exist" ]; then
            sed -i '/ts\.net\/100\.100\.100\.100/d' /etc/dnsmasq.conf
        fi
        /etc/init.d/dnsmasq restart
    fi
}

if [ "$action" = "restart" ];then
    apply_keep_on_upgrade

    # Gate on a tailscaled binary being present (this feed's opkg package OR the
    # Admonstrator build via ts-admon-update). The glue no longer Depends on the
    # opkg binary, so with neither installed there is nothing to start.
    if [ ! -x /usr/sbin/tailscaled ]; then
        logger -t tailscale "gl_tailscale: no tailscaled binary (feed or Admonstrator); nothing to start"
        exit 0
    fi

    for count in `seq 1 10`
    do
        [ $(pgrep -f "tailscaled") ] && break
        sleep 1
    done

    /etc/init.d/tailscale restart

    del_policy_route
    add_ts_fw_rule

    masq=$(uci -q get tailscale.settings.lan_gateway)
    if [ "$masq" = "1" ]; then
        uci set firewall.tailscale0.masq='1'
        uci commit firewall
        /etc/init.d/firewall restart
    else
        if uci get firewall.tailscale0.masq >/dev/null 2>&1; then
            uci set firewall.tailscale0.masq='0'
            uci commit firewall
            /etc/init.d/firewall restart
        fi
    fi

    sys_mode=$(uci -q get glconfig.general.mode)
    if [ "$sys_mode" != "router" ]; then
        /etc/init.d/tailscale stop
        modify_dns_resolv 0
        exit 0
    fi

    enabled=$(uci -q get tailscale.settings.enabled)
    if [ "$enabled" = "1" ]; then
        /sbin/ip rule add to $TAILSCALE_DNS_SERVER lookup $TAILSCALE_ROUTE_TABLE pri 50

        wanip=$(ubus call network.interface.wan status|jsonfilter -e '@["ipv4-address"][0].address')
        wanmask=$(ubus call network.interface.wan status|jsonfilter -e '@["ipv4-address"][0].mask')
        if [ -n "$wanip" ] && [ -n "$wanmask" ] ;then
            wan_network=$(ipcalc_network $wanip $wanmask | awk -F= '/NETWORK/{print $2}')
            wan_mask=$(ipcalc_network $wanip $wanmask | awk -F= '/PREFIX/{print $2}')
        fi
        [ -n "$wan_network" -a -n "$wan_mask" ] && wan_ip="$wan_network/$wan_mask"

        secondwanip=$(ubus call network.interface.secondwan status|jsonfilter -e '@["ipv4-address"][0].address')
        secondwanmask=$(ubus call network.interface.secondwan status|jsonfilter -e '@["ipv4-address"][0].mask')
        if [ -n "$secondwanip" ] && [ -n "$secondwanmask" ] ;then
            secondwan_network=$(ipcalc_network $secondwanip $secondwanmask | awk -F= '/NETWORK/{print $2}')
            secondwan_mask=$(ipcalc_network $secondwanip $secondwanmask | awk -F= '/PREFIX/{print $2}')
        fi
        [ -n "$secondwan_network" -a -n "$secondwan_mask" ] && secondwan_ip="$secondwan_network/$secondwan_mask"

        usbwanip=$(ubus call network.interface.usbwan status|jsonfilter -e '@["ipv4-address"][0].address')
        usbwanmask=$(ubus call network.interface.usbwan status|jsonfilter -e '@["ipv4-address"][0].mask')
        if [ -n "$usbwanip" ] && [ -n "$usbwanmask" ] ;then
            usbwan_network=$(ipcalc_network $usbwanip $usbwanmask | awk -F= '/NETWORK/{print $2}')
            usbwan_mask=$(ipcalc_network $usbwanip $usbwanmask | awk -F= '/PREFIX/{print $2}')
        fi
        [ -n "$usbwan_network" -a -n "$usbwan_mask" ] && usbwan_ip="$usbwan_network/$usbwan_mask"

        wwanip=$(ubus call network.interface.wwan status|jsonfilter -e '@["ipv4-address"][0].address')
        wwanmask=$(ubus call network.interface.wwan status|jsonfilter -e '@["ipv4-address"][0].mask')
        if [ -n "$wwanip" ] && [ -n "$wwanmask" ] ;then
            wwan_network=$(ipcalc_network $wwanip $wwanmask | awk -F= '/NETWORK/{print $2}')
            wwan_mask=$(ipcalc_network $wwanip $wwanmask | awk -F= '/PREFIX/{print $2}')
        fi
        [ -n "$wwan_network" -a -n "$wwan_mask" ] && wwan_ip="$wwan_network/$wwan_mask"

        tetheringip=$(ubus call network.interface.tethering status|jsonfilter -e '@["ipv4-address"][0].address')
        tetheringmask=$(ubus call network.interface.tethering status|jsonfilter -e '@["ipv4-address"][0].mask')
        if [ -n "$tetheringip" ] && [ -n "$tetheringmask" ] ;then
            tethering_network=$(ipcalc_network $tetheringip $tetheringmask | awk -F= '/NETWORK/{print $2}')
            tethering_mask=$(ipcalc_network $tetheringip $tetheringmask | awk -F= '/PREFIX/{print $2}')
        fi
        [ -n "$tethering_network" -a -n "$tethering_mask" ] && tethering_ip="$tethering_network/$tethering_mask"

        lanip=$(uci -q get network.lan.ipaddr)
        lanmask="$(uci -q get network.lan.netmask)"
        lan_network=$(ipcalc_network $lanip $lanmask | awk -F= '/NETWORK/{print $2}')
        lan_mask=$(ipcalc_network $lanip $lanmask | awk -F= '/PREFIX/{print $2}')
        [ -n "$lan_network" -a -n "$lan_mask" ] && lan_ip="$lan_network/$lan_mask"

        run_exit_node=$(uci -q get tailscale.settings.advertise_exit_node)
        exit_node_ip=$(uci -q get tailscale.settings.exit_node_ip)
        lan_enabled=$(uci -q get tailscale.settings.lan_enabled)
        wan_enabled=$(uci -q get tailscale.settings.wan_enabled)
        
        if [ "$lan_enabled" = "1" ]; then
            if [ -n "$lan_ip" ]; then
                [ -n "$routes" ] && routes="$routes,$lan_ip" || routes="$lan_ip"
            fi
        fi

        if [ "$wan_enabled" = "1" ]; then
            if [ -n "$wan_ip" ]; then
                [ -n "$routes" ] && routes="$routes,$wan_ip" || routes="$wan_ip"
            fi

            if [ -n "$wwan_ip" ]; then
                [ -n "$routes" ] && routes="$routes,$wwan_ip" || routes="$wwan_ip"
            fi

            if [ -n "$secondwan_ip" ]; then
                [ -n "$routes" ] && routes="$routes,$secondwan_ip" || routes="$secondwan_ip"
            fi

            if [ -n "$usbwan_ip" ]; then
                [ -n "$routes" ] && routes="$routes,$usbwan_ip" || routes="$usbwan_ip"
            fi

            if [ -n "$tethering_ip" ]; then
                [ -n "$routes" ] && routes="$routes,$tethering_ip" || routes="$tethering_ip"
            fi
        fi

        if [ -n "$routes" ]; then
            param="--advertise-routes=$routes"
        else
            param=""
        fi

        if [ "$run_exit_node" = "1" ]; then
            param="$param --advertise-exit-node"
        fi
        
        if [ -n "$exit_node_ip" ];then
            add_exit_node_rule
            param="$param --exit-node-allow-lan-access --exit-node=$exit_node_ip"
        fi

        [ -n "$lan_ip" ] && add_policy_route $lan_ip

        [ -n "$wan_ip" ] && add_policy_route $wan_ip

        [ -n "$secondwan_ip" ] && add_policy_route $secondwan_ip

        [ -n "$usbwan_ip" ] && add_policy_route $usbwan_ip

        [ -n "$wwan_ip" ] && add_policy_route $wwan_ip

        [ -n "$tethering_ip" ] && add_policy_route $tethering_ip

        add_network_policy_route "guest"
        add_network_policy_route "iot"
        
        timeout 10 /usr/sbin/tailscale up --reset --accept-routes $param --timeout 3s --accept-dns=false > /dev/null
        apply_tailscale_mtu
    else
        /etc/init.d/tailscale stop
    fi

    modify_dns_resolv $enabled
fi
