config settings 'settings'
    option log_stderr '1'
    option log_stdout '1'
    option port '41641'
    option state_file '/etc/tailscale/tailscaled.state'
    # Default the service on for a fresh install. The init script gates the daemon
    # on this flag; starting it only brings tailscaled up idle (NeedsLogin) -- it
    # does not connect to or advertise anything until the user logs in. This is a
    # conffile, so existing users' choice is preserved on upgrade.
    option enabled '1'
    # Preserve the installed Tailscale stack across a GL firmware upgrade by adding
    # it to /etc/sysupgrade.conf. Off by default; toggle on from the panel. Conffile,
    # so an existing user's choice is preserved on upgrade; unset is treated as off.
    option keep_on_upgrade '0'
